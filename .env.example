# Public runtime
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=YOUR_UNSIGNED_UPLOAD_PRESET
NEXT_PUBLIC_CLOUDINARY_FOLDER=yupinitiative/events

# Server runtime
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

RESEND_API_KEY=re_xxxxxxxxx
RESEND_ENABLED=true
RESEND_WEBHOOK_SECRET=YOUR_RESEND_WEBHOOK_SECRET
# Optional legacy var; app now enforces contextual senders under support.yupinitiative.com
RESEND_FROM_EMAIL="YUP Initiative <no-reply@support.yupinitiative.com>"
ADMIN_NOTIFICATION_EMAIL=contact.yupinitiative@gmail.com
# Optional in current segment-only sync mode
RESEND_AUDIENCE_ID=YOUR_RESEND_AUDIENCE_ID
# Required for segment-only contact enrollment
RESEND_COMMUNITY_SEGMENT_ID=YOUR_RESEND_COMMUNITY_SEGMENT_ID
RESEND_NONE_COMMUNITY_SEGMENT_ID=YOUR_RESEND_NONE_COMMUNITY_SEGMENT_ID

ALLOW_ADMIN_SIGNUP=true
